# OpenClaw Python backend env example

OPENCLAW_ENV=dev
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8788

# REST/WS auth token
OPENCLAW_API_TOKEN=openclaw-dev-token
OPENCLAW_JWT_SECRET=openclaw-dev-jwt-secret
OPENCLAW_JWT_ISSUER=openclaw
OPENCLAW_JWT_AUDIENCE=openclaw-web

# Storage
OPENCLAW_DATABASE_URL=sqlite+aiosqlite:///./openclaw.db
OPENCLAW_REDIS_URL=redis://localhost:6379/0
OPENCLAW_VECTOR_BACKEND=memory

# Runtime workspace root used by memory indexing
OPENCLAW_WORKSPACE_DIR=.

# Memory parity configuration
OPENCLAW_MEMORY_ENABLED=true
OPENCLAW_MEMORY_BACKEND=builtin
OPENCLAW_MEMORY_SOURCES=memory
OPENCLAW_MEMORY_EXTRA_PATHS=
OPENCLAW_MEMORY_SESSION_ENABLED=false
OPENCLAW_MEMORY_PROVIDER=local
OPENCLAW_MEMORY_MODEL=openclaw-local-memory-v1
OPENCLAW_MEMORY_FALLBACK=none
OPENCLAW_MEMORY_STORE_PATH=
OPENCLAW_MEMORY_VECTOR_ENABLED=true
OPENCLAW_MEMORY_CHUNK_TOKENS=400
OPENCLAW_MEMORY_CHUNK_OVERLAP=80
OPENCLAW_MEMORY_SYNC_ON_SESSION_START=true
OPENCLAW_MEMORY_SYNC_ON_SEARCH=true
OPENCLAW_MEMORY_SYNC_WATCH=false
OPENCLAW_MEMORY_SYNC_WATCH_DEBOUNCE_MS=1500
OPENCLAW_MEMORY_SYNC_INTERVAL_MINUTES=0
OPENCLAW_MEMORY_SYNC_SESSION_DELTA_BYTES=100000
OPENCLAW_MEMORY_SYNC_SESSION_DELTA_MESSAGES=50
OPENCLAW_MEMORY_MAX_RESULTS=6
OPENCLAW_MEMORY_MIN_SCORE=0.35
OPENCLAW_MEMORY_HYBRID_ENABLED=true
OPENCLAW_MEMORY_HYBRID_VECTOR_WEIGHT=0.7
OPENCLAW_MEMORY_HYBRID_TEXT_WEIGHT=0.3
OPENCLAW_MEMORY_HYBRID_CANDIDATE_MULTIPLIER=4
OPENCLAW_MEMORY_MMR_ENABLED=false
OPENCLAW_MEMORY_MMR_LAMBDA=0.7
OPENCLAW_MEMORY_TEMPORAL_DECAY_ENABLED=false
OPENCLAW_MEMORY_TEMPORAL_DECAY_HALF_LIFE_DAYS=30
OPENCLAW_MEMORY_CACHE_ENABLED=true
OPENCLAW_MEMORY_CACHE_MAX_ENTRIES=10000
OPENCLAW_MEMORY_QMD_COMMAND=
OPENCLAW_MEMORY_QMD_TIMEOUT_MS=30000
OPENCLAW_MEMORY_QMD_MAX_INJECTED_CHARS=12000

# LLM routing defaults
OPENCLAW_DEFAULT_MODEL=openai/echo-default
OPENCLAW_FALLBACK_MODELS=openai/echo-fallback-1,openai/echo-fallback-2

# Tool policy
OPENCLAW_TOOL_ALLOWLIST=clock.now,echo.text,memory.search,memory.get

# Runtime registries (hot-reloadable via /v1/settings or /v1/runtime)
# Entry format: provider/model=Display Name
OPENCLAW_MODEL_REGISTRY=openai/echo-default=Echo Default,openai/echo-fallback-1=Echo Fallback 1,openai/echo-fallback-2=Echo Fallback 2
# Entry format: name=command
OPENCLAW_MCP_SERVERS=qmd=mcporter daemon start
# Comma-separated skill keys from skills/**/SKILL.md
OPENCLAW_SKILLS_ENABLED=
