# OpenClaw Python Backend – Environment Configuration
# Copy to .env and fill in your values

# ─── Server ────────────────────────────────────────────────────────────────
OPENCLAW_ENV=dev
OPENCLAW_HOST=0.0.0.0
OPENCLAW_PORT=8788

# ─── Auth ──────────────────────────────────────────────────────────────────
OPENCLAW_API_TOKEN=openclaw-dev-token
OPENCLAW_JWT_SECRET=openclaw-dev-jwt-secret
OPENCLAW_JWT_ISSUER=openclaw
OPENCLAW_JWT_AUDIENCE=openclaw-web

# ─── Storage ───────────────────────────────────────────────────────────────
OPENCLAW_DATABASE_URL=sqlite+aiosqlite:///./openclaw.db
OPENCLAW_VECTOR_BACKEND=memory
OPENCLAW_WORKSPACE_DIR=.

# ─── LLM Providers (set at least one) ─────────────────────────────────────
# OpenAI / OpenAI-compatible (Groq, Fireworks, Together, etc.)
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1    # default; override for proxies
# OPENAI_BASE_URL=http://localhost:11434/v1    # Ollama via OpenAI-compat layer

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434       # default if Ollama is running

# ─── Default Model (provider/model-id format) ──────────────────────────────
# Examples:
#   openai/gpt-4o
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-5
#   google/gemini-1.5-pro
#   ollama/llama3.2          (local Ollama)
#   openai/echo-default      (stub, no API key needed – for development)
OPENCLAW_DEFAULT_MODEL=openai/gpt-4o-mini

# Fallback models tried in order if primary fails (comma-separated)
OPENCLAW_FALLBACK_MODELS=openai/gpt-3.5-turbo

# ─── Tool Policy ───────────────────────────────────────────────────────────
OPENCLAW_TOOL_ALLOWLIST=clock.now,echo.text,memory.search,memory.get

# ─── Model Registry (displayed in UI; format: provider/model=Display Name) ─
OPENCLAW_MODEL_REGISTRY=openai/gpt-4o=GPT-4o,openai/gpt-4o-mini=GPT-4o Mini,anthropic/claude-sonnet-4-5=Claude Sonnet 4.5,ollama/llama3.2=Llama 3.2 (local)

# ─── MCP Servers (format: name=command) ────────────────────────────────────
# OPENCLAW_MCP_SERVERS=

# ─── Skills ────────────────────────────────────────────────────────────────
OPENCLAW_SKILLS_ENABLED=

# ─── Memory Configuration ──────────────────────────────────────────────────
OPENCLAW_MEMORY_ENABLED=true
OPENCLAW_MEMORY_BACKEND=builtin
OPENCLAW_MEMORY_SOURCES=memory
OPENCLAW_MEMORY_VECTOR_ENABLED=true
OPENCLAW_MEMORY_CHUNK_TOKENS=400
OPENCLAW_MEMORY_CHUNK_OVERLAP=80
OPENCLAW_MEMORY_SYNC_ON_SESSION_START=true
OPENCLAW_MEMORY_SYNC_ON_SEARCH=true
OPENCLAW_MEMORY_MAX_RESULTS=6
OPENCLAW_MEMORY_MIN_SCORE=0.35
OPENCLAW_MEMORY_HYBRID_ENABLED=true
OPENCLAW_MEMORY_HYBRID_VECTOR_WEIGHT=0.7
OPENCLAW_MEMORY_HYBRID_TEXT_WEIGHT=0.3
OPENCLAW_MEMORY_CACHE_ENABLED=true
OPENCLAW_MEMORY_CACHE_MAX_ENTRIES=10000
